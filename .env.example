# Primary app configuration. In GitHub Actions, set this as repository secret APP_CONFIG.
APP_CONFIG={"interests":{"profile":{"enabled":true,"summary":"Urban mobility and climate adaptation","topics":["urban mobility","climate adaptation"],"methods":[],"favoriteJournals":[],"avoidTopics":[],"referencePapers":[]}},"feeds":{"catalogSelections":["Nature"],"customRss":[]},"runtime":{"debug":true,"sendEmpty":true}}

# Optional Zotero settings. Keep ZOTERO_KEY as a secret.
ZOTERO_KEY=your-zotero-api-key

# Required email settings
SENDER=sender@example.com
SENDER_PASSWORD=your-smtp-password-or-app-password
RECEIVER=receiver@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=465

# Optional TLDR generation API.
OPENAI_API_KEY=

# Optional embedding reranker API.
EMBEDDING_API_KEY=
