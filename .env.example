# App configuration lives in config/app.jsonc for local runs.
# Start from config/app.example.jsonc:
#   cp config/app.example.jsonc config/app.jsonc

# Optional Zotero settings. Keep ZOTERO_ID and ZOTERO_KEY as secrets when used.
ZOTERO_ID=1234567
ZOTERO_KEY=example-zotero-api-key

# Required email settings
SENDER=sender@example.com
SENDER_PASSWORD=example-smtp-app-password
RECEIVER=receiver@example.com
SMTP_SERVER=smtp.example.com
SMTP_PORT=465

# Optional TLDR generation API. Leave OPENAI_API_KEY empty to disable summary calls when summary.enabled is false.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Optional embedding reranker API. Leave EMBEDDING_API_KEY empty to fall back to local embeddings.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
